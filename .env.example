# Copy to .env and fill in. Everything has a sensible default except the IPs.

# --- network ---------------------------------------------------------------
# Your PC's LAN address (the one the Nest Hub can reach). Find it with:
#   Windows: ipconfig        Linux/Mac: ip addr / ifconfig
SERVER_IP=192.168.1.10

# The Nest Hub's address, from: catt scan
NEST_HUB_IP=192.168.1.20

# How the frontend container reaches the backend.
#   http://backend:8000              backend in Docker (default)
#   http://host.docker.internal:8000 backend running natively on the host
#                                    (required for keyboard macros + launchers)
BACKEND_URL=http://backend:8000

# --- OBS (only for OBS actions) --------------------------------------------
# In OBS: Tools -> WebSocket Server Settings -> enable, copy the password.
OBS_URL=ws://host.docker.internal:4455
OBS_PASSWORD=

# --- Spotify (only for Spotify actions — see README for the OAuth setup) ---
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://localhost:8000/callback
